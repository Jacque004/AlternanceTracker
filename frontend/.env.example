# Supabase (obligatoire)
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_publique

# URL publique de l’app (pour le lien de confirmation par email — doit pointer vers la prod)
# Sans cela, le lien du mail redirige vers localhost si vous vous inscrivez en local.
VITE_APP_URL=https://jacque004.github.io/AlternanceTracker

# API Backend — en développement, ne pas mettre localhost : l’agrégateur d’offres utilise le proxy Vite (/api → :5000).
# En production (build), définir l’URL publique de l’API :
# VITE_API_URL=https://votre-api.onrender.com/api
